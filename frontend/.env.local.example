# Copy to .env.local and fill in values before running the frontend.

# HTTP(S) URL of the backend — no trailing slash
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# WebSocket URL of the backend
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8000

# Auto-logout after N minutes of inactivity (default: 15)
NEXT_PUBLIC_INACTIVITY_TIMEOUT_MINUTES=15

# Production example:
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com
# NEXT_PUBLIC_BACKEND_WS_URL=wss://your-backend.onrender.com
